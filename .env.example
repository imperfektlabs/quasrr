# Core
COMPOSE_PROJECT_NAME=quasrr
PUID=1000
PGID=1000
TZ=America/New_York
PROJECT_ROOT_PATH=.
BACKEND_PORT=8000
FRONTEND_PORT=3000
DATABASE_PATH=/app/data/quasrr.db
QUASRR_DATA_DIR=./data
QUASRR_CONFIG_DIR=./config
QUASRR_LOGS_DIR=./logs
MEDIA_NETWORK_NAME=net-media

# Integrations
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=your_sonarr_api_key
RADARR_URL=http://radarr:7878
RADARR_API_KEY=your_radarr_api_key
SABNZBD_URL=http://sabnzbd:8080
SABNZBD_API_KEY=your_sabnzbd_api_key
PLEX_URL=http://plex:32400
PLEX_API_KEY=your_plex_api_key
TMDB_API_KEY=your_tmdb_api_key

# Auth
AUTH_SECRET=replace_with_long_random_secret
AUTH_DEFAULT_USERNAME=admin
AUTH_DEFAULT_PASSWORD=change_me

# AI Providers (set what you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
PERPLEXITY_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
LOCAL_API_KEY=

# User Defaults
USER_COUNTRY=US
USER_LANGUAGE=en
LOG_LEVEL=INFO
