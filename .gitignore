# --- .gitignore for Media Stack ---

# 0. Scratch Folder
.scratch/


# 1. System Junk
.DS_Store
Thumbs.db

# 2. Secrets (Passwords/API Keys)
*.env
settings.yaml
TODOS.md

# 3. Data Volumes (The heavy stuff)
# This wildcard ignores every folder ending in "_data"
*_data/

# Image files
*.svg
*.avif
*.png


# Prompts for agents
prompts/
AGENT_INIT*.md
EXECUTION*.md
SESSION*.md

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/


# 5. Node.js / Frontend
node_modules/
.next/
next-env.d.ts
package-lock.json


# IDE
.vscode/
.idea/
*.swp
*.swo



# Test / Coverage
.coverage
htmlcov/
.pytest_cache/

# Docker
docker-compose.override.yml
