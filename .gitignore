# --- .gitignore for Media Stack ---

# 1. System Junk
.DS_Store
Thumbs.db

# 2. Secrets (Passwords/API Keys)
*.env
settings.yaml

# 3. Data Volumes (The heavy stuff)
# This wildcard ignores every folder ending in "_data"
*_data/

# Image files
*.svg
*.avif

# 4. Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/

# 5. Node.js / Frontend
node_modules/
.next/
next-env.d.ts
package-lock.json