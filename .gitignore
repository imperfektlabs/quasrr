# --- Project .gitignore ---

# 0. Local/Environment-Specific Files
# Convention: prefix with _ for files that shouldn't be committed
_*
.recollect/
.scratch/

# AI Agent Directories (developer-specific)
.claude/
.codex/
.cursor/
.vscode/

# 1. System Junk
.DS_Store
Thumbs.db

# 2. Secrets (Passwords/API Keys)
*.env
.env.local
settings.yaml


# 3. Data Volumes (The heavy stuff)
# This wildcard ignores every folder ending in "_data"
*_data/
*data/

# Image files
*.svg
*.avif
*.png


# Prompts for agents



# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/


# 5. Node.js / Frontend
node_modules/
.next/
next-env.d.ts
package-lock.json


# IDE
.vscode/
.idea/
*.swp
*.swo



# Test / Coverage
.coverage
htmlcov/
.pytest_cache/

# Docker
docker-compose.override.yml
